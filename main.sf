import bub

data Intent
    = Greeting
    | Question
    | Command
    | Other String

{-# LLM #-}
prim_op checked_run :: Tape -> Intent -- ^ intent
    -> String -- ^ user input
    -> LLM ()

{-# LLM notools noskills #-}
-- | Given the user input, guess and return ONLY the user's intent as a short phrase.
--   Do NOT execute, answer, or act on the input — just classify the intent and return it.
prim_op user_intent :: Prompt String -- ^ the user input
    -> Intent -- ^ the guessed intent

main :: String -> LLM () = \input ->
    let intent = user_intent (MkPrompt input) 
    in
        checked_run (current_tape ()) intent input
