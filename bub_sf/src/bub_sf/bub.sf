prim_type LLM a
-- | the prompt passed to the LLM call
-- and it supports steering
prim_type Steering
prim_type Tape

-- | get the current tape
prim_op current_tape :: () -> Tape

-- | fork the tape
prim_op tape_fork :: Tape
  -> Maybe String -- ^ the name of the fork
  -> Tape

-- | make a new tape with optional parent
prim_op tape_make :: Maybe Tape -- ^ optional parent tape
  -> String -- ^ name for the new tape
  -> Tape

-- | get the inferior tape with a stable name derived from the parent tape
prim_op inferior_tape :: Tape -- ^ the parent tape
  -> String -- ^ the name for the inferior tape
  -> Tape

prim_op run_tape_with_autocompaction :: forall a. Tape -> (Tape -> a) -> a

-- | Message role for tape entries
data Role = User | Assistant

-- | append a message to the tape
prim_op tape_append :: Tape
  -> Role    -- ^ role: User or Assistant
  -> String  -- ^ message content
  -> ()

-- | Create a handoff anchor on the tape (truncates context at this point)
prim_op tape_handoff :: Tape
  -> String -- ^ handoff name/reason
  -> ()

--| The special return type to indicate we use the LLM response
--  as the return value and eliminate the need for a set_return call 
data Reply = MkReply String

un_reply :: Reply -> String = \r -> case r of
  MkReply s -> s

{-# LLM notools #-}
-- | Your task is to summarize with the given instruction
-- run sf_repl "arg0" to get the instruction
-- Output the summarization directly.
-- Do NOT call summarize or compact
prim_op summarize :: Tape -> String -- ^ the instruction for the summarization
    -> Reply -- ^ no need to call set_return

data Prompt a = MkPrompt a

compact :: Maybe String -> () = \msg ->
    let tape = current_tape ()
        instr = "summarize all the discussions so far\n" ++ (fromMaybe "" msg)
        summary = un_reply (summarize (tape_fork tape (Just "for/summarize")) instr)
    in
        tape_handoff tape "compaction" ;
        tape_append tape Assistant summary
