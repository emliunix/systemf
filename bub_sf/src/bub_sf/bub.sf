prim_type LLM a
prim_type Tape

-- | get the current tape
prim_op current_tape :: () -> Tape

-- | fork the tape
prim_op fork_tape :: Tape
  -> Maybe String -- ^ the name of the fork
  -> Tape

-- | make a new tape with optional parent
prim_op make_tape :: Maybe Tape -- ^ optional parent tape
  -> String -- ^ name for the new tape
  -> Tape

-- | Message role for tape entries
data Role = User | Assistant

-- | append a message to the tape
prim_op tape_append :: Tape
  -> Role    -- ^ role: User or Assistant
  -> String  -- ^ message content
  -> ()

-- | Create a handoff anchor on the tape (truncates context at this point)
prim_op tape_handoff :: Tape
  -> String -- ^ handoff name/reason
  -> ()

--| The special return type to indicate we use the LLM response
--  as the return value and eliminate the need for a set_return call 
data Reply = MkReply String

un_reply :: Reply -> String = \r -> case r of
  MkReply s -> s
