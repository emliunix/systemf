-- ============================================================
-- System F REPL Test Suite
-- ============================================================
-- Run with: uv run python -m systemf.eval.repl -p prelude.sf < test-suite.sf
-- Or interactively copy/paste sections
-- ============================================================

-- ============================================================
-- TEST CATEGORY 1: Basic Literals and Types
-- ============================================================

-- Test 1.1: Integer literal
test_int :: Int = 42

-- Test 1.2: Boolean values
test_true :: Bool = True
test_false :: Bool = False

-- Test 1.3: Wildcard type inference
test_wildcard :: _ = 123

-- ============================================================
-- TEST CATEGORY 2: Arithmetic Operations
-- ============================================================

-- These use primitives from prelude
-- Note: In REPL, you can also use operators: 1 + 2, 5 * 3, etc.

-- Test 2.1: Addition via primitive
test_add :: Int = int_plus 1 2

-- Test 2.2: Multiplication
test_mult :: Int = int_multiply 4 5

-- Test 2.3: Subtraction
test_sub :: Int = int_minus 10 3

-- ============================================================
-- TEST CATEGORY 3: Simple Functions
-- ============================================================

-- Test 3.1: Identity function (monomorphic)
id_int :: Int → Int = λx → x
test_id_int :: Int = id_int 42

-- Test 3.2: Constant function
const_int :: Int → Int → Int = λx y → x
test_const :: Int = const_int 5 10

-- Test 3.3: Function with wildcard type
id_auto :: _ = λx → x
test_id_auto :: Int = id_auto 100

-- ============================================================
-- TEST CATEGORY 4: Polymorphic Functions
-- ============================================================

-- Test 4.1: Polymorphic identity (using implicit type abstraction)
poly_id :: ∀a. a → a = λx → x

-- Test 4.2: Apply polymorphic function
test_poly_id_int :: Int = poly_id @Int 42
test_poly_id_bool :: Bool = poly_id @Bool True

-- Test 4.3: Polymorphic constant
poly_const :: ∀a b. a → b → a = λx y → x
test_poly_const :: Int = poly_const @Int @Bool 42 True

-- ============================================================
-- TEST CATEGORY 5: Data Types and Constructors
-- ============================================================

-- These use types defined in prelude: Maybe, List, Either

-- Test 5.1: Maybe constructors
just_val :: Maybe Int = Just 42
nothing_val :: Maybe Int = Nothing

-- Test 5.2: List constructors
empty_list :: List Int = Nil
single_item :: List Int = Cons 42 Nil
two_items :: List Int = 1 : 2 : Nil

-- Test 5.3: Either constructors
left_val :: Either Int Bool = Left 42
right_val :: Either Int Bool = Right True

-- ============================================================
-- TEST CATEGORY 6: Pattern Matching
-- ============================================================

-- Test 6.1: Simple pattern match on Maybe
from_maybe :: Int → Maybe Int → Int
from_maybe = λdefault m →
  case m of
    Nothing → default
    Just x → x

test_from_just :: Int = from_maybe 0 (Just 42)
test_from_nothing :: Int = from_maybe 0 Nothing

-- Test 6.2: Pattern match on List (length)
length_list :: List Int → Int
length_list = λxs →
  case xs of
    Nil → 0
    Cons y ys → int_plus 1 (length_list ys)

test_length_empty :: Int = length_list Nil
test_length_two :: Int = length_list (1 : 2 : Nil)

-- Test 6.3: Pattern match with wildcards
is_empty :: List Int → Bool
is_empty = λxs →
  case xs of
    Nil → True
    Cons _ _ → False

test_is_empty_true :: Bool = is_empty Nil
test_is_empty_false :: Bool = is_empty (Cons 1 Nil)

-- ============================================================
-- TEST CATEGORY 7: Higher-Order Functions
-- ============================================================

-- Test 7.1: Map for List (polymorphic)
map_list :: ∀a b. (a → b) → List a → List b
map_list = λf xs →
  case xs of
    Nil → Nil
    Cons y ys → Cons (f y) (map_list f ys)

-- Test with increment
test_map_inc :: List Int = map_list (λx → int_plus x 1) (1 : 2 : Nil)

-- Test 7.2: Filter for List
filter_list :: ∀a. (a → Bool) → List a → List a
filter_list = λp xs →
  case xs of
    Nil → Nil
    Cons y ys →
      case p y of
        True → Cons y (filter_list p ys)
        False → filter_list p ys

-- Keep only positive numbers (assuming > 0)
test_filter :: List Int = filter_list (λx → True) (1 : 2 : Nil)

-- ============================================================
-- TEST CATEGORY 8: Recursive Functions
-- ============================================================

-- Test 8.1: Factorial
factorial :: Int → Int
factorial = λn →
  case int_eq n 0 of
    True → 1
    False → int_multiply n (factorial (int_minus n 1))

test_fact_0 :: Int = factorial 0
test_fact_5 :: Int = factorial 5

-- Test 8.2: Fibonacci
fib :: Int → Int
fib = λn →
  case int_lt n 2 of
    True → n
    False → int_plus (fib (int_minus n 1)) (fib (int_minus n 2))

test_fib_0 :: Int = fib 0
test_fib_5 :: Int = fib 5

-- ============================================================
-- TEST CATEGORY 9: Function Composition
-- ============================================================

-- Test 9.1: Simple composition
compose :: ∀a b c. (b → c) → (a → b) → a → c
compose = λf g x → f (g x)

-- Test composition: add 1 then multiply by 2
add1 :: Int → Int = λx → int_plus x 1
mul2 :: Int → Int = λx → int_multiply x 2
test_compose :: Int = compose @Int @Int @Int mul2 add1 5  -- (5+1)*2 = 12

-- ============================================================
-- TEST CATEGORY 10: Boolean Operations
-- ============================================================

-- Using primitives from prelude
-- bool_and, bool_or, bool_not

test_and :: Bool = bool_and True True
test_or :: Bool = bool_or False True
test_not :: Bool = bool_not True

-- ============================================================
-- TEST CATEGORY 11: String Operations (if available)
-- ============================================================

-- Test 11.1: String concatenation
test_concat :: String = string_concat "Hello " "World"

-- Test 11.2: String length
test_str_len :: Int = string_length "Hello"

-- ============================================================
-- SUMMARY
-- ============================================================
-- If all these work, the elaborator handles:
-- ✓ Basic types and literals
-- ✓ Primitive operations
-- ✓ Monomorphic functions
-- ✓ Polymorphic functions with implicit type abstraction
-- ✓ Data type constructors
-- ✓ Pattern matching
-- ✓ Higher-order functions
-- ✓ Recursion
-- ✓ Function composition
-- ✓ Boolean logic
-- ✓ String operations
--
-- Known limitations to test:
-- - Implicit instantiation (needs explicit @T for polymorphic functions)
-- - Let bindings in expressions
-- - Complex nested pattern matching
-- - Mutually recursive functions
-- ============================================================
